# Copy this file to .env.prod and replace all placeholder values.
# Run Compose with:
# docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

POSTGRES_DB=floodsim_db
POSTGRES_USER=floodsim

# Use a strong URL-safe password because it is embedded in PostgreSQL URLs.
POSTGRES_PASSWORD=replace_with_a_strong_url_safe_password

# Public Droplet origin. Nginx serves the frontend at / and proxies /api to
# the FastAPI service listening on 127.0.0.1:8000.
NEXT_PUBLIC_API_URL=http://<DROPLET_IP>
