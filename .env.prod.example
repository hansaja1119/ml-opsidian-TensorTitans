# Copy this file to .env.prod and replace all placeholder values.
# Never commit .env.prod; it contains production secrets.
# Run Compose with:
# docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

POSTGRES_DB=floodsim_db
POSTGRES_USER=floodsim

# Use a strong URL-safe password because it is embedded in PostgreSQL URLs.
POSTGRES_PASSWORD=replace_with_a_strong_url_safe_password

# Public origin used by the browser. If Nginx proxies /api to FastAPI, this
# can be the same public origin as the frontend.

# If using direct IP:
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP

# If using a domain later:
# NEXT_PUBLIC_API_URL=https://your-domain.com
